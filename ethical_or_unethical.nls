extensions [ time ]

globals [
  ;diversity            ;; mutation strength during reproduction
  ;average-ethicality   ;; initial level of ethicality for population
  
  ; THE PAY-OFF SYSTEM
  T                    ;; +3 for unethicaleing and fooling other party
  R                    ;; +2 reward for both parties for co-operating
  P                    ;;  0 if the two parties defraud each other
  S                    ;; -1 for the party that get defrauded
  avg-score
  avg-ethicality
]

turtles-own [
  ethicality           ;; moral character (0-100)
  myscore              ;; fitness score, determines whether they live or die
  behavior             ;; records whether the people are acting ethically or not.
  
  strategy             ;; This will store which of the five types the agent is
  has-been-cheated?    ;; Boolean value for wheather the agents have been defrauded or not.
  sequence-step        ;; This is specifically for the Detective Agent.
  last-action          ;; will help the copying agent determine the past behavior of patner.
  
]

;; The setup is divided into 2 procedures
to setup
  clear-all
  setup-turtles
  set T 3
  set R 2
  set P 0
  set S -1
  reset-ticks 
end

;; Create agents
to setup-turtles

  create-turtles number-of-agents [
    
    set shape turtle-shape
    setxy random-xcor random-ycor
    set size 1.5  ;; easier to see
    assign-strategy
    set has-been-cheated? false
    set sequence-step 0 
    set last-action "ethical"
    
    ; Ethicality drawn from normal distribution
    set ethicality round random-normal average-ethicality diversity
    bound-ethicality
    
    ; Set the initial score to a random number between 1-100
    set myscore random 100
    
    recolor
  ]
end

to go
  if ticks >= 500 [stop]
  
  ask turtles [move]
  interact
  ifelse any? turtles [
    set avg-score mean [myscore] of turtles
    set avg-ethicality mean [ethicality] of turtles
  ][
    set avg-score 0
    set avg-ethicality 0
  ]
  reproduce
  update-visuals
  update-labels
  update-plots
  tick              
end

;; Turtles move about at random.
to move ;; turtle procedure
  rt random 360
  fd 1
end

;; To assign startegies that would be used in each simulation.
to assign-strategy
  let n random-float 100
  
  if n < percent-copying [
    set strategy "copying"
  ]
  if n >= percent-copying and n < percent-copying + percent-frauds [
    set strategy "fraud"
  ]
  if n >= percent-copying + percent-frauds and n < percent-copying + percent-frauds + percent-cooperative [
    set strategy "cooperator"
  ]
  if n >=  percent-copying + percent-frauds + percent-cooperative and n < percent-copying + percent-frauds + percent-cooperative + percent-avenger [
    set strategy "avenger"
  ]
  if n >= percent-copying + percent-frauds + percent-cooperative + percent-avenger and n < percent-copying + percent-frauds + percent-cooperative + percent-avenger + percent-detective [
    set strategy "detective"
  ]
end

; makes a pair interact once before the agents move on to find another partner
to interact
  ask turtles [
    if any? other turtles-here [
      let partner one-of other turtles-here
      if who < [who] of partner [
        repeat 20[
          interact-with partner
        ]
      ]
    ]
  ]
end

to interact-with [partner]
  let my-action decide-action partner
  let partner-action [decide-action myself] of partner
  
  ;; store behavior BEFORE payoff
  set behavior my-action
  ask partner [ set behavior partner-action ]
  
  ;; Updates Ethciality
  if my-action = "ethical" [
    set ethicality ethicality + 1
  ]
  if my-action = "unethical" [
    set ethicality ethicality - 1
  ]
  bound-ethicality
  
  ;; update ethciality for partner
  ask partner[
    if partner-action = "ethical" [
      set ethicality ethicality + 1
    ]
    if partner-action = "unethical" [
      set ethicality ethicality - 1
    ]
    bound-ethicality
  ]
  
  apply-payoff partner my-action partner-action
  
  ;; memory update
  if partner-action = "unethical" [
    set has-been-cheated? true
  ]
  
  set last-action my-action
  ask partner [set last-action partner-action]
end


;; This decides the actions that each agent take.
to-report decide-action [partner]

  ;; The cooperatiove agent is always ethical
  if strategy = "cooperator" [
    report "ethical"
  ]
  
  ;; the fraud agent always defrauds its partner
  if strategy = "fraud" [
    report "unethical"
  ]
  
  ;; the avenger agent is always ethical until its been defrauded then it begins to defraud its partner forever
  if strategy = "avenger" [
    if has-been-cheated? [
      report "unethical"
    ]
    report "ethical"
  ]
  
  ;; the copying agent starts ethical then copies the last move of its partner
  if strategy = "copying" [
    ifelse [last-action] of partner = "unethical" [
      report "unethical"
    ][
      report "ethical"
    ]
  ]
  
  
  ;; The detective agents utilizes the strategy of the copying and fraud agent. 
  if strategy = "detective" [
    ;; the detective is to probe the partner before deciding acting like the copying agents
    ;; probe sequence: E -> U -> E -> E (where E is ethical and U unethical)
    if sequence-step = 0 [ set sequence-step 1 report "ethical" ]
    if sequence-step = 1 [ set sequence-step 2 report "unethical" ]
    if sequence-step = 2 [ set sequence-step 3 report "ethical"]
    if sequence-step = 3 [ set sequence-step 4 report "ethical"]
    
    ;; This agent decides after the probing phase whether to become a copying or fraud
    ;; agent based on his interactions with his partner
    if sequence-step >= 4[
      ;; Become copying agent if ever cheated
      if has-been-cheated? [
        ifelse[last-action] of partner = "unethical"[
          report "unethical"
        ][
          report "ethical"
        ]
      ]
      ;; else become fraud agent
      if not has-been-cheated? [
        report "unethical"
      ]
    ]  
 ]
  
  ;; safety net
  report "ethical"
end


;; This is the implementation of the Prisoner's Dillema as a reward systen for the agents
to apply-payoff [partner my-action partner-action]

  ;; ethical / ethical
  if my-action = "ethical" and partner-action = "ethical" [
    set myscore myscore + R
    ask partner [ set myscore myscore + R ]
  ]
  
  ;; unethical / unethical
  if my-action = "unethical" and partner-action = "unethical" [
    set myscore myscore + P
    ask partner [ set myscore myscore + P ]
  ]
  
  ;; unethical vs ethical
  if my-action = "unethical" and partner-action = "ethical" [
    set myscore myscore + T
    ask partner [ set myscore myscore + S ]
  ]
  
  ;; ethical vs unethical
  if my-action = "ethical" and partner-action = "unethical" [
    set myscore myscore + S
    ask partner [ set myscore myscore + T ]
  ]

end



;; This is what decides or affects the diversity rate of the turtles. Evolutionary Selection
;; The 3 with lowest scores die and the 3 with highest score duplicate and their score halfens
to reproduce
  let n count turtles
  if n = 0 [ stop ]  ;; safety

  let k min list 3 n  ;; choose up to 3, but not more than available

  ;; kill worst performers
  ask min-n-of k turtles [myscore] [ die ]

  ;; recompute count after deaths
  let survivors count turtles
  if survivors = 0 [ stop ]

  let k2 min list 3 survivors

  ;; reproduce top performers
  ask max-n-of k2 turtles [myscore] [
    set myscore myscore / 2
    hatch 1[
      move
      
      ;; inherit strategy
      set strategy [strategy] of myself
  
      ;; mutation
      if random-float 100 < 5 [
        assign-strategy
      ]
  
      ;; inherit ethicality mutated
      set ethicality ethicality + random 5 - 2
      bound-ethicality
  
      set myscore random 100
      recolor
    ]
  ]
end

to bound-ethicality
  if ethicality < 0 [ set ethicality 0]
  if ethicality > 100 [set ethicality 100] 
end

; If they maintain good ethical conduct they are presented as gree, else they are red
to recolor
  if ethicality > 50 [
    set color green
  ]
  if ethicality <= 50 [
    set color red
  ]
end

to update-visuals
  ask turtles [recolor]
end

;; Labels the agents on the patch.
to update-labels
  ask turtles [
    let short-strat ""

    if strategy = "copying" [ set short-strat "C" ]
    if strategy = "fraud" [ set short-strat "F" ]
    if strategy = "cooperator" [ set short-strat "Co" ]
    if strategy = "avenger" [ set short-strat "A" ]
    if strategy = "detective" [ set short-strat "D" ]

    set label (word short-strat "\ne:" ethicality "\ns:" myscore)
  ]
end
